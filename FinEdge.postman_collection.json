{
  "info": {
    "name": "FinEdge",
    "description": "Personal Finance Tracker API. Full collection covering health, users, transactions, budgets, and summary.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000" },
    { "key": "token", "value": "" },
    { "key": "transactionId", "value": "" },
    { "key": "budgetId", "value": "" }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "GET /health",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/health",
              "host": ["{{baseUrl}}"],
              "path": ["health"]
            }
          }
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "POST /users: Register",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const res = pm.response.json();",
                  "if (res && res.token) {",
                  "  pm.collectionVariables.set('token', res.token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Alice\",\n  \"email\": \"alice@example.com\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/users",
              "host": ["{{baseUrl}}"],
              "path": ["users"]
            }
          }
        }
      ]
    },
    {
      "name": "Transactions",
      "item": [
        {
          "name": "POST /transactions: Create expense",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const res = pm.response.json();",
                  "if (res && res.transaction && res.transaction.id) {",
                  "  pm.collectionVariables.set('transactionId', res.transaction.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"type\": \"expense\",\n  \"category\": \"Groceries\",\n  \"amount\": 1500,\n  \"date\": \"2026-04-15\",\n  \"description\": \"Weekly grocery run\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/transactions",
              "host": ["{{baseUrl}}"],
              "path": ["transactions"]
            }
          }
        },
        {
          "name": "POST /transactions: Create income",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"type\": \"income\",\n  \"category\": \"Salary\",\n  \"amount\": 75000,\n  \"date\": \"2026-04-01\",\n  \"description\": \"Monthly salary\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/transactions",
              "host": ["{{baseUrl}}"],
              "path": ["transactions"]
            }
          }
        },
        {
          "name": "GET /transactions: List all",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/transactions",
              "host": ["{{baseUrl}}"],
              "path": ["transactions"]
            }
          }
        },
        {
          "name": "GET /transactions: Filter by type and date range",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/transactions?type=expense&startDate=2026-01-01&endDate=2026-04-30",
              "host": ["{{baseUrl}}"],
              "path": ["transactions"],
              "query": [
                { "key": "type", "value": "expense" },
                { "key": "startDate", "value": "2026-01-01" },
                { "key": "endDate", "value": "2026-04-30" }
              ]
            }
          }
        },
        {
          "name": "GET /transactions/:id",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/transactions/{{transactionId}}",
              "host": ["{{baseUrl}}"],
              "path": ["transactions", "{{transactionId}}"]
            }
          }
        },
        {
          "name": "PATCH /transactions/:id",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": 1750,\n  \"category\": \"Food\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/transactions/{{transactionId}}",
              "host": ["{{baseUrl}}"],
              "path": ["transactions", "{{transactionId}}"]
            }
          }
        },
        {
          "name": "DELETE /transactions/:id",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/transactions/{{transactionId}}",
              "host": ["{{baseUrl}}"],
              "path": ["transactions", "{{transactionId}}"]
            }
          }
        }
      ]
    },
    {
      "name": "Budgets",
      "item": [
        {
          "name": "POST /budgets: Create",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const res = pm.response.json();",
                  "if (res && res.budget && res.budget.id) {",
                  "  pm.collectionVariables.set('budgetId', res.budget.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": \"user-1\",\n  \"month\": \"2026-04\",\n  \"monthlyGoal\": 50000,\n  \"savingsTarget\": 10000\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/budgets",
              "host": ["{{baseUrl}}"],
              "path": ["budgets"]
            }
          }
        },
        {
          "name": "GET /budgets: List all",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/budgets",
              "host": ["{{baseUrl}}"],
              "path": ["budgets"]
            }
          }
        },
        {
          "name": "GET /budgets: Filter by user and month",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/budgets?userId=user-1&month=2026-04",
              "host": ["{{baseUrl}}"],
              "path": ["budgets"],
              "query": [
                { "key": "userId", "value": "user-1" },
                { "key": "month", "value": "2026-04" }
              ]
            }
          }
        },
        {
          "name": "GET /budgets/:id",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/budgets/{{budgetId}}",
              "host": ["{{baseUrl}}"],
              "path": ["budgets", "{{budgetId}}"]
            }
          }
        },
        {
          "name": "PATCH /budgets/:id",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"monthlyGoal\": 55000\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/budgets/{{budgetId}}",
              "host": ["{{baseUrl}}"],
              "path": ["budgets", "{{budgetId}}"]
            }
          }
        },
        {
          "name": "DELETE /budgets/:id",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/budgets/{{budgetId}}",
              "host": ["{{baseUrl}}"],
              "path": ["budgets", "{{budgetId}}"]
            }
          }
        }
      ]
    },
    {
      "name": "Summary",
      "item": [
        {
          "name": "GET /summary: Default",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/summary",
              "host": ["{{baseUrl}}"],
              "path": ["summary"]
            }
          }
        },
        {
          "name": "GET /summary: Filter by category",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/summary?category=Groceries",
              "host": ["{{baseUrl}}"],
              "path": ["summary"],
              "query": [
                { "key": "category", "value": "Groceries" }
              ]
            }
          }
        },
        {
          "name": "GET /summary: Filter by date range",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/summary?startDate=2026-01-01&endDate=2026-04-30",
              "host": ["{{baseUrl}}"],
              "path": ["summary"],
              "query": [
                { "key": "startDate", "value": "2026-01-01" },
                { "key": "endDate", "value": "2026-04-30" }
              ]
            }
          }
        }
      ]
    }
  ]
}
